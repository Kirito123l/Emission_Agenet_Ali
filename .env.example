# Minimal setup notes:
# 1. Copy this file to `.env`.
# 2. `python main.py health` and most local tests can run without real provider keys.
# 3. Router-mode evaluation and live chat usually require at least one reachable provider.
# 4. Standardization and evaluation ablations can be driven by the switches in this file.

# ============ Provider Credentials & Endpoints ============
# Qwen provider
QWEN_API_KEY=sk-xxx
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_MODELS={"max": "qwen-max", "plus": "qwen-plus", "turbo": "qwen-turbo-latest"}

# DeepSeek provider
DEEPSEEK_API_KEY=sk-xxx
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODELS={"flash": "deepseek-v4-flash", "pro": "deepseek-v4-pro"}

# Local / OpenAI-compatible provider
LOCAL_LLM_API_KEY=not-needed
LOCAL_LLM_BASE_URL=http://localhost:8000/v1
LOCAL_LLM_MODEL=local-model

# ============ Model Assignment ============
# One-switch defaults. Purpose-specific variables below are optional overrides.
LLM_PROVIDER=qwen
LLM_REASONING_MODEL=qwen3-max
LLM_FAST_MODEL=qwen-turbo-latest
# true means stale AGENT_LLM_* process vars are ignored unless the override is written in `.env`.
LLM_USE_GLOBAL_DEFAULTS=true
DEEPSEEK_ENABLE_THINKING=true
DEEPSEEK_REASONING_EFFORT=high
DEEPSEEK_THINKING_MODELS=deepseek-v4-pro

# Agent planning and tool-orchestration model
# AGENT_LLM_PROVIDER=qwen
# AGENT_LLM_MODEL=qwen3-max

# Parameter-standardization model assignment
# STANDARDIZER_LLM_PROVIDER=qwen
# STANDARDIZER_LLM_MODEL=qwen-turbo-latest

# Final response synthesis model assignment
# SYNTHESIS_LLM_PROVIDER=qwen
# SYNTHESIS_LLM_MODEL=qwen3-max

# RAG refinement model assignment
# RAG_REFINER_LLM_PROVIDER=qwen
# RAG_REFINER_LLM_MODEL=qwen-turbo-latest

# ============ Core Runtime Switches ============
# Global model-backed parameter standardization switch
ENABLE_LLM_STANDARDIZATION=true
# Collect standardization training/evaluation samples
ENABLE_DATA_COLLECTION=true
# Enable structured file analysis before routing
ENABLE_FILE_ANALYZER=true
# Inject grounded file context into prompts
ENABLE_FILE_CONTEXT_INJECTION=true
# Enable executor-side parameter standardization
ENABLE_EXECUTOR_STANDARDIZATION=true
# Enable state-machine orchestration path
ENABLE_STATE_ORCHESTRATION=true
# Attach decision trace to router responses
ENABLE_TRACE=true
# Persist completed traces to `data/traces/`
PERSIST_TRACE=false
# Persist live router workflow state for follow-up turns after restarts
ENABLE_LIVE_STATE_PERSISTENCE=true
# Enable conservative conversational fast path before state-loop routing
ENABLE_CONVERSATION_FAST_PATH=true
# Enable layered memory prompt injection shared by fast path and state loop
ENABLE_LAYERED_MEMORY_CONTEXT=true
# Enable the explicit session-state prompt block
ENABLE_SESSION_STATE_BLOCK=false
# Use GovernedRouter for production agent routing
ENABLE_GOVERNED_ROUTER=true
# Retry transient LLM connection failures with bounded backoff
ENABLE_LLM_RETRY_BACKOFF=true
# Generate contour-band GeoJSON alongside raster outputs
ENABLE_CONTOUR_OUTPUT=true
# Interpolation grid resolution for contour generation (meters)
CONTOUR_INTERP_RESOLUTION_M=10.0
# Number of contour isobands to generate
CONTOUR_N_LEVELS=7
# Gaussian smoothing sigma in contour-grid cells
CONTOUR_SMOOTH_SIGMA=1.0
# Directory for server-generated static map exports
MAP_EXPORT_DIR=data/exports
# Default DPI for exported PNG/PDF/SVG maps
MAP_EXPORT_DPI=300
# Default format for server-generated map exports
MAP_EXPORT_DEFAULT_FORMAT=png
# Cleanup threshold for generated map export files
MAP_EXPORT_TTL_HOURS=1
# Enable basemap fetching during static map export
MAP_EXPORT_BASEMAP_ENABLED=true
# Set to false on servers without outbound internet to skip basemap download attempts entirely
# Timeout in seconds for preflight tile-server connectivity checks
MAP_EXPORT_BASEMAP_TIMEOUT=2
# Allow fuzzy matching stages in parameter standardization
STANDARDIZATION_FUZZY_ENABLED=true

# ============ AO / Governance Contracts ============
# Enable AO-aware memory and prompt surfaces
ENABLE_AO_AWARE_MEMORY=true
# Enable rule-based AO classification
ENABLE_AO_CLASSIFIER_RULE_LAYER=true
# Enable LLM-backed AO classification fallback
ENABLE_AO_CLASSIFIER_LLM_LAYER=true
# AO classifier model and thresholds. Defaults to LLM_FAST_MODEL when omitted.
# AO_CLASSIFIER_MODEL=qwen-plus
AO_CLASSIFIER_CONFIDENCE_THRESHOLD=0.7
AO_CLASSIFIER_TIMEOUT_SEC=5.0
# Inject AO block into governed prompts
ENABLE_AO_BLOCK_INJECTION=true
# Persist AO-scoped facts
ENABLE_AO_PERSISTENT_FACTS=true
# AO block token budget
AO_BLOCK_TOKEN_BUDGET=1200
# Keep AO as first-class persistent state
ENABLE_AO_FIRST_CLASS_STATE=true
# Enable legacy clarification contract when contract split is disabled
ENABLE_CLARIFICATION_CONTRACT=true
# Split clarification into intent/stance/readiness contracts
ENABLE_CONTRACT_SPLIT=false
ENABLE_SPLIT_INTENT_CONTRACT=true
ENABLE_SPLIT_STANCE_CONTRACT=true
ENABLE_SPLIT_READINESS_CONTRACT=true
# Runtime-default-aware readiness checks
ENABLE_RUNTIME_DEFAULT_AWARE_READINESS=true
# Persist split continuation state
ENABLE_SPLIT_CONTINUATION_STATE=true
# Enable Stage 2 LLM clarification pass
ENABLE_CLARIFICATION_STAGE2_LLM=true
# Defaults to LLM_FAST_MODEL when omitted.
# CLARIFICATION_LLM_MODEL=qwen-plus
CLARIFICATION_LLM_TIMEOUT_SEC=5.0
CLARIFICATION_LLM_CONFIDENCE_THRESHOLD=0.7
# Comma-separated confirmation-first signals/patterns
CLARIFICATION_CONFIRM_FIRST_SIGNALS=先确认,先帮我确认,先看看,确认参数,确认一下,列一下参数,参数是什么,怎么设置,怎么算,需要什么,帮我算,confirm first,check first,let me confirm,what parameters,need to specify,how to set
CLARIFICATION_CONFIRM_FIRST_PATTERNS=need_parameters_fuzzy,leading_sequence_marker,parameter_request
# Enable LLM intent and lifecycle alignment layers
ENABLE_LLM_INTENT_RESOLUTION=true
ENABLE_LIFECYCLE_CONTRACT_ALIGNMENT=true
# Enable conversational stance resolution
ENABLE_CONVERSATIONAL_STANCE=true
ENABLE_STANCE_LLM_RESOLUTION=true
ENABLE_STANCE_REVERSAL_DETECTION=true
STANCE_SIGNALS_PATH=config/stance_signals.yaml

# ============ Planning / Repair / Templates ============
# Enable lightweight planning prompt before execution
ENABLE_LIGHTWEIGHT_PLANNING=false
# Enable bounded plan repair logic
ENABLE_BOUNDED_PLAN_REPAIR=false
# Enable repair-aware continuation prompting
ENABLE_REPAIR_AWARE_CONTINUATION=false
# Enable workflow-template recommendation and injection
ENABLE_WORKFLOW_TEMPLATES=false
# Maximum number of workflow-template recommendations
WORKFLOW_TEMPLATE_MAX_RECOMMENDATIONS=3
# Minimum confidence required to apply a workflow template prior
WORKFLOW_TEMPLATE_MIN_CONFIDENCE=0.55
# Continuation prompt variant name
CONTINUATION_PROMPT_VARIANT=balanced_repair_aware
# Maximum number of state-orchestration loop steps
MAX_ORCHESTRATION_STEPS=4

# ============ Parameter Governance ============
# Enable post-standardization cross-constraint validation
ENABLE_CROSS_CONSTRAINT_VALIDATION=true
# Enable parameter negotiation when confidence is low
ENABLE_PARAMETER_NEGOTIATION=true
# Negotiation threshold below which confirmation is required
PARAMETER_NEGOTIATION_CONFIDENCE_THRESHOLD=0.85
# Maximum number of negotiation candidates to surface
PARAMETER_NEGOTIATION_MAX_CANDIDATES=5

# ============ Readiness / Completion / Recovery ============
# Enable capability-aware synthesis constraints
ENABLE_CAPABILITY_AWARE_SYNTHESIS=true
# Enable readiness gating before tool execution
ENABLE_READINESS_GATING=true
# Mark some readiness failures as repairable rather than hard-blocked
READINESS_REPAIRABLE_ENABLED=true
# Suppress already-delivered follow-up actions
READINESS_ALREADY_PROVIDED_DEDUP_ENABLED=true
# Enable structured input-completion flow
ENABLE_INPUT_COMPLETION_FLOW=true
# Max number of structured input-completion options
INPUT_COMPLETION_MAX_OPTIONS=4
# Permit uniform-scalar completion option
INPUT_COMPLETION_ALLOW_UNIFORM_SCALAR=true
# Permit upload-support-file completion option
INPUT_COMPLETION_ALLOW_UPLOAD_SUPPORT_FILE=true
# Enable geometry-recovery path for spatial workflows
ENABLE_GEOMETRY_RECOVERY_PATH=true
# Allowed file types for geometry recovery
GEOMETRY_RECOVERY_SUPPORTED_FILE_TYPES=geojson,json,shp,zip,csv,xlsx,xls
# Require readiness refresh after geometry recovery
GEOMETRY_RECOVERY_REQUIRE_READINESS_REFRESH=true
# Enable file-relationship resolution for new uploads
ENABLE_FILE_RELATIONSHIP_RESOLUTION=true
# Require a newly uploaded file for relationship resolution
FILE_RELATIONSHIP_RESOLUTION_REQUIRE_NEW_UPLOAD=true
# Allow LLM fallback in file-relationship resolution
FILE_RELATIONSHIP_RESOLUTION_ALLOW_LLM_FALLBACK=true
# Enable bounded supplemental-column merge
ENABLE_SUPPLEMENTAL_COLUMN_MERGE=true
# Allow alias keys during supplemental merge
SUPPLEMENTAL_MERGE_ALLOW_ALIAS_KEYS=true
# Require readiness refresh after supplemental merge
SUPPLEMENTAL_MERGE_REQUIRE_READINESS_REFRESH=true
# Enable residual re-entry controller
ENABLE_RESIDUAL_REENTRY_CONTROLLER=true
# Require the residual target to be ready before biasing continuation
RESIDUAL_REENTRY_REQUIRE_READY_TARGET=true
# Prefer recovered targets during residual re-entry
RESIDUAL_REENTRY_PRIORITIZE_RECOVERY_TARGET=true

# ============ Intent / Artifact / Delivery Surfaces ============
# Enable intent-resolution layer for follow-up actions
ENABLE_INTENT_RESOLUTION=true
# Allow LLM fallback in intent resolution
INTENT_RESOLUTION_ALLOW_LLM_FALLBACK=true
# Bias follow-up suggestions using intent resolution
INTENT_RESOLUTION_BIAS_FOLLOWUP_SUGGESTIONS=true
# Bias continuation prompting using intent resolution
INTENT_RESOLUTION_BIAS_CONTINUATION=true
# Enable artifact-memory tracking across turns
ENABLE_ARTIFACT_MEMORY=true
# Track textual summary artifacts in memory
ARTIFACT_MEMORY_TRACK_TEXTUAL_SUMMARY=true
# Deduplicate artifacts by family
ARTIFACT_MEMORY_DEDUP_BY_FAMILY=true
# Bias follow-up suggestions using artifact memory
ARTIFACT_MEMORY_BIAS_FOLLOWUP=true
# Enable bounded summary-delivery surface
ENABLE_SUMMARY_DELIVERY_SURFACE=true
# Allow ranked bar-chart delivery in summary surface
SUMMARY_DELIVERY_ENABLE_BAR_CHART=true
# Default top-k used by summary delivery
SUMMARY_DELIVERY_DEFAULT_TOPK=5
# Allow text-only fallback in summary delivery
SUMMARY_DELIVERY_ALLOW_TEXT_FALLBACK=true

# ============ Remediation / Default Policies ============
# Enable policy-based remediation paths
ENABLE_POLICY_BASED_REMEDIATION=true
# Allow default typical-profile remediation
ENABLE_DEFAULT_TYPICAL_PROFILE_POLICY=true
# Task types allowed to use default typical-profile remediation
DEFAULT_TYPICAL_PROFILE_ALLOWED_TASK_TYPES=macro_emission

# ============ File Analysis Fallback ============
# Allow LLM fallback when rule-based file analysis is low-confidence
ENABLE_FILE_ANALYSIS_LLM_FALLBACK=false
# Confidence threshold below which file-analysis fallback may trigger
FILE_ANALYSIS_FALLBACK_CONFIDENCE_THRESHOLD=0.72
# Max sample rows forwarded into file-analysis fallback
FILE_ANALYSIS_FALLBACK_MAX_SAMPLE_ROWS=3
# Max columns forwarded into file-analysis fallback
FILE_ANALYSIS_FALLBACK_MAX_COLUMNS=25
# Allow ZIP table selection during file-analysis fallback
FILE_ANALYSIS_FALLBACK_ALLOW_ZIP_TABLE_SELECTION=true

# ============ Tool / Renderer Surface ============
# Enable built-in map-data payloads
ENABLE_BUILTIN_MAP_DATA=false
# Enable prompt-time skill injection
ENABLE_SKILL_INJECTION=true
# Enabled macro column-mapping stages
MACRO_COLUMN_MAPPING_MODES=direct,ai,fuzzy

# ============ Standardization Backend ============
# Explicit nested standardization backend enable switch
STANDARDIZATION_LLM_ENABLED=true
# Standardization model backend type: `api` or another backend name
STANDARDIZATION_LLM_BACKEND=api
# Override standardization model name if needed
STANDARDIZATION_LLM_MODEL=
# Standardization model timeout in seconds
STANDARDIZATION_LLM_TIMEOUT=5.0
# Standardization model retry count
STANDARDIZATION_LLM_MAX_RETRIES=1
# Default fuzzy threshold when custom per-type threshold is not provided
STANDARDIZATION_FUZZY_THRESHOLD=0.7
# Optional local distilled-model path for standardization
STANDARDIZATION_LOCAL_MODEL_PATH=

# ============ Local Standardizer ============
# Use the local distilled/fine-tuned standardizer backend
USE_LOCAL_STANDARDIZER=false
# Local backend mode: `direct` or `vllm`
LOCAL_STANDARDIZER_MODE=direct
# Local base model path or HF identifier
LOCAL_STANDARDIZER_BASE_MODEL=Qwen/Qwen2.5-3B-Instruct
# Unified LoRA path for the local standardizer
LOCAL_STANDARDIZER_UNIFIED_LORA=./LOCAL_STANDARDIZER_MODEL/models/unified_lora/final
# Column LoRA path for the local standardizer
LOCAL_STANDARDIZER_COLUMN_LORA=./LOCAL_STANDARDIZER_MODEL/models/column_lora/checkpoint-200
# Local inference device: `cuda` or `cpu`
LOCAL_STANDARDIZER_DEVICE=cuda
# Local standardizer max token length
LOCAL_STANDARDIZER_MAX_LENGTH=256
# vLLM endpoint for local standardizer serving
LOCAL_STANDARDIZER_VLLM_URL=http://localhost:8001

# ============ Retrieval / Embedding ============
# Embedding mode: `api` or `local`
EMBEDDING_MODE=api
# Rerank mode: `api`, `local`, or `none`
RERANK_MODE=api
# Embedding model name
EMBEDDING_MODEL=text-embedding-v3
# Embedding vector dimension
EMBEDDING_DIMENSION=1024
# Rerank model name
RERANK_MODEL=gte-rerank
# Top-N candidates preserved after reranking
RERANK_TOP_N=5

# ============ Paths / Networking ============
# Directory for collected standardization/evaluation samples
DATA_COLLECTION_DIR=data/collection
# Directory for runtime logs
LOG_DIR=data/logs
# Directory for generated artifacts
OUTPUTS_DIR=outputs
# Optional HTTP proxy
HTTP_PROXY=
# Optional HTTPS proxy
HTTPS_PROXY=

# ============ Security / Server Extras ============
# Strong JWT signing secret for auth-enabled deployments
JWT_SECRET_KEY=change-me-to-a-strong-random-secret
# Optional API port used by server entrypoints outside config.py
PORT=8000
# Optional log level used by logging setup outside config.py
LOG_LEVEL=INFO
